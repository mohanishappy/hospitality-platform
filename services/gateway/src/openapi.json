{
  "openapi": "3.0.3",
  "info": {
    "title": "Hospitality Platform API",
    "description": "Gateway surface for **inventory** (hotels, room types) and **reservations**. Send requests to the gateway URL; it validates **Auth0** JWTs and forwards to backing Workers (injects `x-chain-id` from the token).\n\n**Token:** Bearer access token with `aud` = your API identifier and a tenant claim: claim key **`https://hospitality.app/claims/chain_id`** (string UUID), or **`chain_id`** — must match an `inventory.chain` row.\n\n**Errors:** JSON **`application/problem+json`** with `type`, `title`, `detail`, `status` (see schema **Problem**).",
    "version": "1.0.0",
    "contact": { "name": "Hospitality Platform" }
  },
  "servers": [
    {
      "url": "/",
      "description": "Gateway origin (same scheme/host as this document)."
    }
  ],
  "tags": [
    { "name": "Meta", "description": "Health and documentation" },
    { "name": "Inventory", "description": "Hotels and room types for the caller's chain" },
    { "name": "Reservations", "description": "Bookings and guest updates" }
  ],
  "paths": {
    "/health": {
      "get": {
        "tags": ["Meta"],
        "summary": "Gateway health",
        "operationId": "getHealth",
        "responses": {
          "200": {
            "description": "Service is reachable",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["ok", "service"],
                  "properties": {
                    "ok": { "type": "boolean", "example": true },
                    "service": { "type": "string", "example": "gateway" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/health/ready": {
      "get": {
        "tags": ["Meta"],
        "summary": "Gateway readiness (Auth0 JWKS)",
        "description": "Public. Verifies **`AUTH0_DOMAIN`** / **`AUTH0_AUDIENCE`** are set and **`GET …/jwks.json`** succeeds within a short timeout. Does not call Supabase.",
        "operationId": "getHealthReady",
        "responses": {
          "200": {
            "description": "JWKS reachable",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["ok", "service", "checks"],
                  "properties": {
                    "ok": { "type": "boolean", "example": true },
                    "service": { "type": "string", "example": "gateway" },
                    "checks": {
                      "type": "object",
                      "properties": {
                        "jwks": { "type": "boolean" }
                      }
                    }
                  }
                }
              }
            }
          },
          "503": {
            "description": "Misconfiguration or JWKS fetch failed",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": { "type": "boolean" },
                    "service": { "type": "string" },
                    "checks": { "type": "object" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/openapi.json": {
      "get": {
        "tags": ["Meta"],
        "summary": "OpenAPI document",
        "operationId": "getOpenApi",
        "responses": {
          "200": {
            "description": "OpenAPI 3.0 JSON",
            "content": {
              "application/json": {
                "schema": { "type": "object" }
              }
            }
          }
        }
      }
    },
    "/v1/inventory/hotels": {
      "get": {
        "tags": ["Inventory"],
        "summary": "List hotels",
        "operationId": "listHotels",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Hotels for the JWT chain",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["hotels"],
                  "properties": {
                    "hotels": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/HotelSummary" }
                    }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "500": { "$ref": "#/components/responses/Problem" }
        }
      }
    },
    "/v1/inventory/hotels/{id}": {
      "get": {
        "tags": ["Inventory"],
        "summary": "Get hotel by id",
        "operationId": "getHotelById",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "Hotel detail",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["hotel"],
                  "properties": {
                    "hotel": { "$ref": "#/components/schemas/HotelDetail" }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/Problem" },
          "500": { "$ref": "#/components/responses/Problem" }
        }
      }
    },
    "/v1/inventory/hotels/{hotelId}/room-types": {
      "get": {
        "tags": ["Inventory"],
        "summary": "List room types for a hotel",
        "operationId": "listRoomTypes",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "hotelId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "Room types (code-ordered)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["hotel_id", "room_types"],
                  "properties": {
                    "hotel_id": { "type": "string", "format": "uuid" },
                    "room_types": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/RoomType" }
                    }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/Problem" },
          "500": { "$ref": "#/components/responses/Problem" }
        }
      }
    },
    "/v1/inventory/search": {
      "get": {
        "tags": ["Inventory"],
        "summary": "Search bookable room types for a stay (FR-V1)",
        "description": "Returns all room types in the chain (optionally filtered by **`hotel_ids`**) that pass **hotel booking policies**. Each row includes **`bookable`**, **`pricing`** (same rules as **GET …/availability**), and identifiers. Sort by **`price`** (default) or **`bookable`** first.",
        "operationId": "inventorySearchStays",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "check_in",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "format": "date" }
          },
          {
            "name": "check_out",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "format": "date" }
          },
          {
            "name": "hotel_ids",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Comma-separated hotel UUIDs; omit for all hotels in the chain."
          },
          {
            "name": "sort",
            "in": "query",
            "schema": { "type": "string", "enum": ["price", "bookable"], "default": "price" }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer", "minimum": 1, "maximum": 100, "default": 20 }
          },
          {
            "name": "rate_plan_code",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Optional rate plan code (must match when set)."
          },
          {
            "name": "promotion_code",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Optional promotion code."
          }
        ],
        "responses": {
          "200": {
            "description": "Ordered search hits",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["results"],
                  "properties": {
                    "results": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/InventorySearchHit" }
                    }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/Problem" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "500": { "$ref": "#/components/responses/Problem" }
        }
      }
    },
    "/v1/inventory/hotels/{hotelId}/room-types/{roomTypeId}/calendar": {
      "get": {
        "tags": ["Inventory"],
        "summary": "Per-day availability for a room type (FR-V2)",
        "description": "Half-open **`[from, to)`** date range. Each day includes **occupancy**, **units_blocked** (maintenance/holds), **sellable_capacity**, **remaining_units**, and **bookable**.",
        "operationId": "getRoomTypeAvailabilityCalendar",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "hotelId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          },
          {
            "name": "roomTypeId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          },
          {
            "name": "from",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "format": "date" }
          },
          {
            "name": "to",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "format": "date" },
            "description": "Exclusive end date"
          }
        ],
        "responses": {
          "200": {
            "description": "Array of day objects",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["days"],
                  "properties": {
                    "days": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/CalendarDay" }
                    }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/Problem" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "500": { "$ref": "#/components/responses/Problem" }
        }
      }
    },
    "/v1/inventory/hotels/{hotelId}/room-types/{roomTypeId}/availability": {
      "get": {
        "tags": ["Inventory"],
        "summary": "Availability and price quote for a stay",
        "description": "Per-**night** capacity: sellable units = **`units_total` + `overbooking_allowance` − inventory blocks**. A stay is bookable when **every** night in **[check_in, check_out)** has remaining capacity. **Pricing** resolves **rate plans** (LOS tiers) and optional **promotions**, then **tax** and **fees** (see migration **0014**).",
        "operationId": "getRoomTypeAvailability",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "hotelId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          },
          {
            "name": "roomTypeId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          },
          {
            "name": "check_in",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "format": "date" },
            "description": "Arrival (YYYY-MM-DD), inclusive"
          },
          {
            "name": "check_out",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "format": "date" },
            "description": "Departure (YYYY-MM-DD), exclusive; must be after check_in"
          },
          {
            "name": "rate_plan_code",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Optional rate plan code."
          },
          {
            "name": "promotion_code",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Optional promotion code."
          }
        ],
        "responses": {
          "200": {
            "description": "Quote and occupancy snapshot",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["availability"],
                  "properties": {
                    "availability": { "$ref": "#/components/schemas/AvailabilityQuote" }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/Problem" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "500": { "$ref": "#/components/responses/Problem" }
        }
      }
    },
    "/v1/reservations": {
      "get": {
        "tags": ["Reservations"],
        "summary": "List reservations",
        "operationId": "listReservations",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer", "minimum": 1, "maximum": 100, "default": 20 }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": { "type": "integer", "minimum": 0, "default": 0 }
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["pending", "confirmed", "cancelled"]
            },
            "description": "Filter by reservation status."
          },
          {
            "name": "hotel_id",
            "in": "query",
            "schema": { "type": "string", "format": "uuid" },
            "description": "Filter by hotel."
          },
          {
            "name": "stay_from",
            "in": "query",
            "schema": { "type": "string", "format": "date" },
            "description": "Start of stay overlap window (YYYY-MM-DD). Use with **`stay_to`**."
          },
          {
            "name": "stay_to",
            "in": "query",
            "schema": { "type": "string", "format": "date" },
            "description": "End of overlap window (YYYY-MM-DD), exclusive. Reservations overlapping **[stay_from, stay_to)** are returned."
          }
        ],
        "responses": {
          "200": {
            "description": "Newest first; list rows omit nested guest",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["reservations", "limit", "offset", "has_more"],
                  "properties": {
                    "reservations": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/ReservationListItem" }
                    },
                    "limit": { "type": "integer" },
                    "offset": { "type": "integer" },
                    "has_more": { "type": "boolean" }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/Problem" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "500": { "$ref": "#/components/responses/Problem" }
        }
      },
      "post": {
        "tags": ["Reservations"],
        "summary": "Create reservation (idempotent)",
        "description": "Requires **`Idempotency-Key`** (UUID recommended). First request **201** + `idempotent_replay: false`; same key replays **200** + `idempotent_replay: true`. Dates **YYYY-MM-DD**; availability is **per night**: **`units_total` + `overbooking_allowance`** must exceed concurrent **pending**/**confirmed** stays on each night in **[check_in, check_out)** (see **GET …/availability**).",
        "operationId": "createReservation",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "Idempotency-Key",
            "in": "header",
            "required": true,
            "schema": { "type": "string" },
            "description": "Stable key per logical create; replays return the same reservation."
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateReservationRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Idempotent replay",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CreateReservationResponse" }
              }
            }
          },
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CreateReservationResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/Problem" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "409": {
            "description": "Computed total does not match **`expected_total_cents`** (price changed since quote).",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Problem" }
              }
            }
          },
          "500": { "$ref": "#/components/responses/Problem" }
        }
      }
    },
    "/v1/reservations/{id}": {
      "get": {
        "tags": ["Reservations"],
        "summary": "Get reservation by id",
        "operationId": "getReservationById",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "Includes nested **guest**",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["reservation"],
                  "properties": {
                    "reservation": { "$ref": "#/components/schemas/ReservationDetail" }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/Problem" },
          "500": { "$ref": "#/components/responses/Problem" }
        }
      },
      "patch": {
        "tags": ["Reservations"],
        "summary": "Update reservation status",
        "description": "Lifecycle: **pending** → **confirmed** | **cancelled**; **confirmed** → **cancelled**. Same status is a no-op.**409** if transition invalid.",
        "operationId": "patchReservationStatus",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ReservationStatusPatch" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated or no-op",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["reservation"],
                  "properties": {
                    "reservation": { "$ref": "#/components/schemas/ReservationDetail" }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/Problem" },
          "409": { "$ref": "#/components/responses/Problem" },
          "500": { "$ref": "#/components/responses/Problem" }
        }
      }
    },
    "/v1/reservations/{id}/guest": {
      "patch": {
        "tags": ["Reservations"],
        "summary": "Patch guest contact fields",
        "description": "At least one of **first_name**, **last_name**, **email**, **phone**. Use **`null`** for **phone** to clear.",
        "operationId": "patchGuest",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Reservation id",
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/GuestPatch" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Guest and reservation timestamps updated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["reservation"],
                  "properties": {
                    "reservation": { "$ref": "#/components/schemas/ReservationDetail" }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/Problem" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/Problem" },
          "500": { "$ref": "#/components/responses/Problem" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Auth0 access token with required `aud` and `https://hospitality.app/claims/chain_id` (or `chain_id`)."
      }
    },
    "schemas": {
      "Problem": {
        "type": "object",
        "required": ["type", "title", "detail", "status"],
        "properties": {
          "type": { "type": "string", "example": "about:blank#missing-token" },
          "title": { "type": "string" },
          "detail": { "type": "string" },
          "status": { "type": "integer", "example": 401 }
        }
      },
      "HotelSummary": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "code": { "type": "string" },
          "chain_id": { "type": "string", "format": "uuid" }
        }
      },
      "HotelDetail": {
        "allOf": [
          { "$ref": "#/components/schemas/HotelSummary" },
          {
            "type": "object",
            "properties": {
              "created_at": { "type": "string", "format": "date-time" }
            }
          }
        ]
      },
      "RoomType": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "hotel_id": { "type": "string", "format": "uuid" },
          "chain_id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "code": { "type": "string" },
          "capacity": { "type": "integer" },
          "created_at": { "type": "string", "format": "date-time" },
          "units_total": { "type": "integer" },
          "base_rate_cents": { "type": "integer", "nullable": true },
          "currency": { "type": "string", "nullable": true },
          "overbooking_allowance": { "type": "integer", "description": "Extra sellable units beyond units_total (oversell cap)" },
          "tax_rate_bps": { "type": "integer", "description": "Tax in basis points (10000 = 100%) applied to room subtotal" },
          "fee_fixed_cents": { "type": "integer", "description": "Flat fee per stay in minor units" }
        }
      },
      "AvailabilityQuote": {
        "type": "object",
        "description": "JSON object returned by room_type_availability_quote RPC",
        "properties": {
          "room_type_id": { "type": "string" },
          "hotel_id": { "type": "string" },
          "check_in": { "type": "string", "format": "date" },
          "check_out": { "type": "string", "format": "date" },
          "nights": { "type": "integer" },
          "units_total": { "type": "integer" },
          "overbooking_allowance": { "type": "integer" },
          "sellable_capacity": { "type": "integer" },
          "max_night_occupancy": { "type": "integer" },
          "remaining_units_on_tightest_night": { "type": "integer" },
          "bookable": { "type": "boolean" },
          "pricing": { "$ref": "#/components/schemas/StayPricingQuote" }
        }
      },
      "StayPricingQuote": {
        "type": "object",
        "properties": {
          "currency": { "type": "string" },
          "base_rate_cents_per_night": { "type": "integer", "nullable": true },
          "nightly_rate_cents": { "type": "integer", "nullable": true, "description": "After rate plan / LOS tier resolution" },
          "nights": { "type": "integer" },
          "room_subtotal_cents": { "type": "integer", "nullable": true },
          "discount_cents": { "type": "integer", "description": "Promotion discount on room subtotal before tax" },
          "tax_rate_bps": { "type": "integer" },
          "tax_cents": { "type": "integer" },
          "fee_fixed_cents": { "type": "integer" },
          "fee_line_items": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/FeeLineItem" }
          },
          "total_cents": { "type": "integer" },
          "rate_plan_code": { "type": "string", "nullable": true },
          "promotion_code": { "type": "string", "nullable": true }
        }
      },
      "InventorySearchHit": {
        "type": "object",
        "properties": {
          "hotel_id": { "type": "string" },
          "hotel_name": { "type": "string" },
          "room_type_id": { "type": "string" },
          "room_type_name": { "type": "string" },
          "check_in": { "type": "string", "format": "date" },
          "check_out": { "type": "string", "format": "date" },
          "nights": { "type": "integer" },
          "bookable": { "type": "boolean" },
          "pricing": { "type": "object", "description": "Output of compute_stay_pricing (JSON)" }
        }
      },
      "CalendarDay": {
        "type": "object",
        "properties": {
          "date": { "type": "string", "format": "date" },
          "occupancy": { "type": "integer" },
          "units_blocked": { "type": "integer" },
          "sellable_capacity": { "type": "integer" },
          "remaining_units": { "type": "integer" },
          "bookable": { "type": "boolean" }
        }
      },
      "FeeLineItem": {
        "type": "object",
        "properties": {
          "code": { "type": "string" },
          "label": { "type": "string" },
          "amount_cents": { "type": "integer" }
        }
      },
      "PricingSnapshot": {
        "type": "object",
        "description": "Commercial snapshot persisted at booking time (FR-C4/C5).",
        "properties": {
          "currency": { "type": "string" },
          "room_subtotal_cents": { "type": "integer" },
          "tax_cents": { "type": "integer" },
          "fee_line_items": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/FeeLineItem" }
          },
          "total_cents": { "type": "integer" }
        }
      },
      "ReservationListItem": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "chain_id": { "type": "string", "format": "uuid" },
          "hotel_id": { "type": "string", "format": "uuid" },
          "room_type_id": { "type": "string", "format": "uuid" },
          "check_in": { "type": "string", "format": "date" },
          "check_out": { "type": "string", "format": "date" },
          "status": {
            "type": "string",
            "enum": ["pending", "confirmed", "cancelled"]
          },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" },
          "pricing_snapshot": {
            "nullable": true,
            "allOf": [{ "$ref": "#/components/schemas/PricingSnapshot" }]
          }
        }
      },
      "Guest": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "first_name": { "type": "string" },
          "last_name": { "type": "string" },
          "email": { "type": "string" },
          "phone": { "type": "string", "nullable": true },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "ReservationDetail": {
        "allOf": [
          { "$ref": "#/components/schemas/ReservationListItem" },
          {
            "type": "object",
            "properties": {
              "guest": {
                "nullable": true,
                "allOf": [{ "$ref": "#/components/schemas/Guest" }]
              }
            }
          }
        ]
      },
      "CreateReservationRequest": {
        "type": "object",
        "required": ["hotel_id", "room_type_id", "check_in", "check_out", "guest"],
        "properties": {
          "hotel_id": { "type": "string", "format": "uuid" },
          "room_type_id": { "type": "string", "format": "uuid" },
          "check_in": { "type": "string", "format": "date", "example": "2026-06-01" },
          "check_out": { "type": "string", "format": "date", "example": "2026-06-04" },
          "rate_plan_code": {
            "type": "string",
            "nullable": true,
            "description": "Optional; must match server pricing when set."
          },
          "promotion_code": {
            "type": "string",
            "nullable": true,
            "description": "Optional promotion code."
          },
          "expected_total_cents": {
            "type": "integer",
            "minimum": 0,
            "description": "If set, create fails with **409** when it does not match the computed total (quote parity)."
          },
          "guest": {
            "type": "object",
            "required": ["first_name", "last_name", "email"],
            "properties": {
              "first_name": { "type": "string" },
              "last_name": { "type": "string" },
              "email": { "type": "string" },
              "phone": { "type": "string", "nullable": true }
            }
          }
        }
      },
      "CreateReservationResponse": {
        "type": "object",
        "required": ["reservation", "idempotency_key", "idempotent_replay"],
        "properties": {
          "reservation": { "$ref": "#/components/schemas/ReservationDetail" },
          "idempotency_key": { "type": "string" },
          "idempotent_replay": { "type": "boolean" }
        }
      },
      "ReservationStatusPatch": {
        "type": "object",
        "required": ["status"],
        "properties": {
          "status": {
            "type": "string",
            "enum": ["pending", "confirmed", "cancelled"]
          }
        }
      },
      "GuestPatch": {
        "type": "object",
        "minProperties": 1,
        "properties": {
          "first_name": { "type": "string" },
          "last_name": { "type": "string" },
          "email": { "type": "string" },
          "phone": { "type": "string", "nullable": true }
        },
        "description": "Include at least one property."
      }
    },
    "responses": {
      "Unauthorized": {
        "description": "Missing or invalid Bearer token, or missing chain claim",
        "content": {
          "application/problem+json": {
            "schema": { "$ref": "#/components/schemas/Problem" }
          }
        }
      },
      "Problem": {
        "description": "Error (validation, not found, conflict, server)",
        "content": {
          "application/problem+json": {
            "schema": { "$ref": "#/components/schemas/Problem" }
          }
        }
      }
    }
  }
}
