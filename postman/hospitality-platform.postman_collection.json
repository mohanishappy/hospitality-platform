    },
    {
      "name": "01 — Inventory",
      "auth": {
        "type": "bearer",
        "bearer": [
          {
            "key": "token",
            "value": "{{access_token}}",
            "type": "string"
          }
        ]
      },
      "item": [
        {
          "name": "GET My chains",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const j = pm.response.json();",
                  "    if (j.chains && j.chains[0] && j.chains[0].id) {",
                  "        const id = j.chains[0].id;",
                  "        pm.collectionVariables.set('chain_id', id);",
                  "        if (pm.environment.name) {",
                  "            pm.environment.set('chain_id', id);",
                  "        }",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/v1/inventory/me/chains",
            "description": "Brands the caller may access (gateway-resolved from JWT **`enterprise_id`** + **`inventory.staff_member`** grants). Guests see all enterprise brands. On **200**, saves first **`chain_id`** when present."
          },
          "response": []
        },
        {
          "name": "GET List hotels",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const j = pm.response.json();",
                  "    if (j.hotels && j.hotels[0] && j.hotels[0].id) {",
                  "        const id = j.hotels[0].id;",
                  "        pm.collectionVariables.set('hotel_id', id);",
                  "        if (pm.environment.name) {",
                  "            pm.environment.set('hotel_id', id);",
                  "        }",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/v1/inventory/hotels",
            "description": "Returns `hotels[]` for allowed brand scope. With **`chain_code`** set, filters to that active brand via **`x-chain-code`**. On **200**, saves first hotel `id` to **collection** and **active environment**."
          },
          "response": []
        },
        {
          "name": "GET Hotel by id",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/v1/inventory/hotels/{{hotel_id}}",
            "description": "Single hotel for the token’s chain. **404** if id not in chain."
          },
          "response": []
        },
        {
          "name": "GET Room types for hotel",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const j = pm.response.json();",
                  "    if (j.room_types && j.room_types[0] && j.room_types[0].id) {",
                  "        const id = j.room_types[0].id;",
                  "        pm.collectionVariables.set('room_type_id', id);",
                  "        if (pm.environment.name) {",
                  "            pm.environment.set('room_type_id', id);",
                  "        }",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/v1/inventory/hotels/{{hotel_id}}/room-types",
            "description": "`room_types[]` for this hotel. On **200**, saves first type `id` to `room_type_id`. Run after **GET List hotels** (or set `hotel_id` manually)."
          },
          "response": []
        },
        {
          "name": "GET Room type availability & quote",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/v1/inventory/hotels/{{hotel_id}}/room-types/{{room_type_id}}/availability?check_in={{check_in}}&check_out={{check_out}}&rate_plan_code={{rate_plan_code}}&promotion_code={{promotion_code}}",
            "description": "Per-night **bookable** + **pricing** (rate plans, optional promotions, **inventory blocks**, hotel **booking policies**). Optional query **`rate_plan_code`** / **`promotion_code`** (collection vars; leave empty to skip). Dates should match **POST /v1/reservations**. Requires migration **0014**."
          },
          "response": []
        },
        {
          "name": "GET Search stays",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/v1/inventory/search?check_in={{check_in}}&check_out={{check_out}}&sort=price&limit=20&hotel_ids={{search_hotel_ids}}&rate_plan_code={{rate_plan_code}}&promotion_code={{promotion_code}}",
            "description": "**FR-V1:** all room types in the chain (optionally filter **`hotel_ids`** = comma-separated UUIDs in **`search_hotel_ids`**). Hotels that fail policy checks for the stay are omitted. **`sort`**: `price` (here) or change URL to `sort=bookable`. Optional **`rate_plan_code`** / **`promotion_code`**."
          },
          "response": []
        },
        {
          "name": "GET Room type calendar",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/v1/inventory/hotels/{{hotel_id}}/room-types/{{room_type_id}}/calendar?from={{calendar_from}}&to={{calendar_to}}",
            "description": "**FR-V2:** per-day **occupancy**, **soft_hold_units**, **units_blocked**, **remaining_units**, **bookable** on half-open **[from, to)**. Set **`calendar_from`** / **`calendar_to`** on the collection (e.g. one month). **0015** adds **soft holds** to counts."
          },
          "response": []
        },
        {
          "name": "POST Create soft hold",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const j = pm.response.json();",
                  "    const id = j && j.soft_hold && j.soft_hold.hold_id;",
                  "    if (id) {",
                  "        pm.collectionVariables.set('soft_hold_id', id);",
                  "        if (pm.environment.name) {",
                  "            pm.environment.set('soft_hold_id', id);",
                  "        }",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"check_in\": \"{{check_in}}\",\n  \"check_out\": \"{{check_out}}\",\n  \"ttl_seconds\": 900,\n  \"units_held\": 1\n}"
            },
            "url": "{{baseUrl}}/v1/inventory/hotels/{{hotel_id}}/room-types/{{room_type_id}}/soft-holds",
            "description": "**FR-V5:** temporary capacity lock (**60**–**86400** s TTL). Re-run **GET …/availability** to see **`max_night_including_holds`** / **`bookable`**. Saves **`soft_hold_id`** on **200**."
          },
          "response": []
        },
        {
          "name": "DELETE Release soft hold",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/v1/inventory/soft-holds/{{soft_hold_id}}",
            "description": "Removes hold for this chain. Set **`soft_hold_id`** from **POST Create soft hold**."
          },
          "response": []
        }
      ],
      "description": "Bearer token required; gateway resolves enterprise scope and injects **`x-chain-id`** / **`x-chain-ids`**. Optional **`chain_code`** → **`x-chain-code`** (collection pre-request)."
    },
    {
      "name": "01 — Admin staff",
      "auth": {
        "type": "bearer",
        "bearer": [
          {
            "key": "token",
            "value": "{{access_token}}",
            "type": "string"
          }
        ]
      },
      "item": [
        {
          "name": "GET List staff",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/v1/inventory/admin/staff",
            "description": "List provisioned staff for the token **`enterprise_id`**. Requires **manager** role (**`staff:admin`**). Clear **`chain_code`** if you want enterprise-wide admin context."
          },
          "response": []
        },
        {
          "name": "POST Create staff member",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const j = pm.response.json();",
                  "    const id = j && j.staff && j.staff.id;",
                  "    if (id) {",
                  "        pm.collectionVariables.set('staff_member_id', id);",
                  "        if (pm.environment.name) {",
                  "            pm.environment.set('staff_member_id', id);",
                  "        }",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"frontdesk@example.com\",\n  \"auth0_sub\": \"auth0|REPLACE_WITH_JWT_SUB\",\n  \"display_name\": \"Front Desk Demo\",\n  \"all_chains\": false,\n  \"chain_ids\": [\n    \"a1111111-1111-4111-8111-111111111111\"\n  ]\n}"
            },
            "url": "{{baseUrl}}/v1/inventory/admin/staff",
            "description": "Provision staff (**manager** only). Set **`auth0_sub`** to the user's JWT **`sub`**. Either **`all_chains`: true** or non-empty **`chain_ids`** (Harborline demo UUID shown). Saves **`staff_member_id`** on **201**."
          },
          "response": []
        },
        {
          "name": "PATCH Update staff member",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"display_name\": \"Updated name\",\n  \"active\": true\n}"
            },
            "url": "{{baseUrl}}/v1/inventory/admin/staff/{{staff_member_id}}",
            "description": "Partial update: **`email`**, **`display_name`**, **`active`**, **`all_chains`**. Requires **`staff_member_id`**."
          },
          "response": []
        },
        {
          "name": "PUT Replace staff brand grants",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"chain_ids\": [\n    \"a1111111-1111-4111-8111-111111111111\"\n  ]\n}"
            },
            "url": "{{baseUrl}}/v1/inventory/admin/staff/{{staff_member_id}}/chains",
            "description": "Replace **`staff_chain_grant`** rows. Staff must have **`all_chains`: false**; use **PATCH** to set **`all_chains`: true** for corporate access."
          },
          "response": []
        }
      ],
      "description": "Manager-only staff provisioning (**0018**). Token needs **`manager`** role and matching **`inventory.staff_member`** row. See **`docs/AUTHORIZATION.md`**."
    },
    {
      "name": "02 — Reservations",
      "auth": {
        "type": "bearer",
        "bearer": [
          {
            "key": "token",
            "value": "{{access_token}}",
            "type": "string"
          }
        ]
      },
      "item": [
        {
          "name": "GET List reservations",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/v1/reservations?limit=20&offset=0",
            "description": "Newest first across allowed brands (enterprise staff) or email-scoped (guest). Optional filters (**FR-R8**): **`status`**, **`hotel_id`**, **`chain_id`** (brand UUID — add `&chain_id={{chain_id}}` when **`chain_id`** is set), **`stay_from`** + **`stay_to`**. Response includes `has_more`. No embedded `guest` rows."
          },
          "response": []
        },
        {
          "name": "POST Create reservation",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "function __t(v) {",
                  "    if (v === undefined || v === null) return '';",
                  "    return String(v).trim();",
                  "}",
                  "// Resolved value: environment wins over collection. Generate only when blank.",
                  "var k = __t(pm.variables.get('idempotency_key'));",
                  "if (!k) {",
                  "    k = pm.variables.replaceIn('{{$guid}}');",
                  "    pm.collectionVariables.set('idempotency_key', k);",
                  "    if (pm.environment.name) {",
                  "        pm.environment.set('idempotency_key', k);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const c = pm.response.code;",
                  "if (c === 200 || c === 201) {",
                  "    const j = pm.response.json();",
                  "    if (j && j.reservation && j.reservation.id) {",
                  "        const id = j.reservation.id;",
                  "        pm.collectionVariables.set('reservation_id', id);",
                  "        if (pm.environment.name) {",
                  "            pm.environment.set('reservation_id', id);",
                  "        }",
                  "    }",
                  "    const etag = pm.response.headers.get('ETag');",
                  "    if (etag) {",
                  "        pm.collectionVariables.set('reservation_etag', etag);",
                  "        if (pm.environment.name) {",
                  "            pm.environment.set('reservation_etag', etag);",
                  "        }",
                  "    }",
                  "}",
                  "pm.test('Status is 200 or 201', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Idempotency-Key",
                "value": "{{idempotency_key}}",
                "description": "Resolved from environment or collection; pre-request generates a GUID into **collection** when blank. Clear `idempotency_key` (collection or env) for a new booking; keep the same value to replay (**200**)."
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"hotel_id\": \"{{hotel_id}}\",\n  \"room_type_id\": \"{{room_type_id}}\",\n  \"check_in\": \"{{check_in}}\",\n  \"check_out\": \"{{check_out}}\",\n  \"rate_plan_code\": \"{{rate_plan_code}}\",\n  \"promotion_code\": \"{{promotion_code}}\",\n  \"guest\": {\n    \"first_name\": \"Ada\",\n    \"last_name\": \"Lovelace\",\n    \"email\": \"ada@example.com\",\n    \"phone\": \"+1-555-0100\"\n  }\n}"
            },
            "url": "{{baseUrl}}/v1/reservations",
            "description": "First send sets **`reservation_id`** on the **collection** (use **Collection** → **Variables** to inspect). For a **new** booking, clear **`idempotency_key`**; pre-request fills a new GUID on the collection when resolved value is blank. Re-send **without** clearing to test replay (**200** + `idempotent_replay: true`). Optional **`rate_plan_code`** / **`promotion_code`** must match **GET …/availability** for the same stay (or omit / leave collection vars empty). Pricing snapshot + **`expected_total_cents`** parity: migration **0013**+."
          },
          "response": []
        },
        {
          "name": "GET Reservation by id",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const etag = pm.response.headers.get('ETag');",
                  "    if (etag) {",
                  "        pm.collectionVariables.set('reservation_etag', etag);",
                  "        if (pm.environment.name) {",
                  "            pm.environment.set('reservation_etag', etag);",
                  "        }",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/v1/reservations/{{reservation_id}}",
            "description": "Uses `{{reservation_id}}` (Postman: **environment** overrides **collection** for the same name). Saves **`reservation_etag`** from **`ETag`** for optional **PATCH** concurrency (**FR-R11**)."
          },
          "response": []
        },
        {
          "name": "PATCH Guest contact",
          "event": [
            {
              "listen": "test",
