# Copy to .env.e2e (gitignored) for automated admin smoke + Playwright UI tests.
# Use manager@plg.demo after linking auth0_sub in inventory.staff_member (see README).

AUTH0_DOMAIN=dev-xxxxx.us.auth0.com
AUTH0_CLIENT_ID=your_spa_client_id
# Required if Password grant is enabled on a confidential app; leave empty for public SPA + Password
AUTH0_CLIENT_SECRET=
AUTH0_AUDIENCE=https://hospitality-api

E2E_MANAGER_EMAIL=manager@plg.demo
E2E_MANAGER_PASSWORD=your_test_password

# Optional overrides
GATEWAY_BASE_URL=https://hospitality-gateway.mohanishhappy.workers.dev
WEB_BASE_URL=https://hospitality-web-bfc.pages.dev
ENTERPRISE_CODE=PLG
